#!/usr/bin/env bash
# Convert Claude-style agent markdown files into Codex TOML agents.

set -euo pipefail

source_dir="${1:-}"
target_dir="${2:-}"

if [ -z "$source_dir" ] || [ -z "$target_dir" ]; then
  echo "usage: convert-claude-agents-to-codex <source-dir> <target-dir>" >&2
  exit 2
fi

python - "$source_dir" "$target_dir" <<'PY'
import json
import sys
from pathlib import Path

src_dir = Path(sys.argv[1])
dst_dir = Path(sys.argv[2])

if not src_dir.exists():
    raise SystemExit(0)

dst_dir.mkdir(parents=True, exist_ok=True)

for src in sorted(src_dir.glob("*.md")):
    text = src.read_text(encoding="utf-8-sig")
    if not text.startswith("---"):
        continue

    end = text.find("\n---", 3)
    if end == -1:
        continue

    frontmatter = text[3:end].strip()
    body_start = text.find("\n", end + 1)
    body = text[body_start + 1:].lstrip() if body_start != -1 else ""

    name = None
    description = None
    lines = frontmatter.splitlines()
    i = 0

    while i < len(lines):
        line = lines[i]
        if line.startswith("name:"):
            name = line.split(":", 1)[1].strip().strip('"')
        elif line.startswith("description:"):
            value = line.split(":", 1)[1].strip()
            if value in (">", "|"):
                parts = []
                i += 1
                while i < len(lines) and (lines[i].startswith(" ") or not lines[i].strip()):
                    stripped = lines[i].strip()
                    if stripped:
                        parts.append(stripped)
                    i += 1
                i -= 1
                description = " ".join(parts)
            else:
                description = value.strip().strip('"')
        i += 1

    if not name or description is None:
        continue

    out = (
        f"name = {json.dumps(name, ensure_ascii=False)}\n"
        f"description = {json.dumps(description, ensure_ascii=False)}\n"
        f"developer_instructions = {json.dumps(body, ensure_ascii=False)}\n"
    )
    (dst_dir / f"{name}.toml").write_text(out, encoding="utf-8")
PY
