#!/usr/bin/env bash
# Copy project-local .agents skills/agents into Claude's project-local folders.

set -euo pipefail

project_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

copy_dir() {
  local source="$1"
  local target="$2"

  if [ ! -d "$source" ]; then
    return 0
  fi

  mkdir -p "$target"

  (
    cd "$source"
    while IFS= read -r -d '' dir; do
      mkdir -p "$target/$dir"
    done < <(find . -type d -print0)

    while IFS= read -r -d '' file; do
      cp -p "$file" "$target/$file"
    done < <(find . -type f -print0)
  )
}

copy_dir "$project_root/.agents/skills" "$project_root/.claude/skills"

exit 0
