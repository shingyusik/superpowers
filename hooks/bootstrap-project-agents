#!/usr/bin/env bash
# Seed project-local Claude/Codex agent folders from this plugin.

set -euo pipefail

script_dir="$(cd "$(dirname "$0")" && pwd)"
plugin_root="$(cd "${script_dir}/.." && pwd)"
project_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

copy_dir() {
  local source="$1"
  local target="$2"

  if [ ! -d "$source" ]; then
    return 0
  fi

  mkdir -p "$target"

  (
    cd "$source"
    while IFS= read -r -d '' dir; do
      mkdir -p "$target/$dir"
    done < <(find . -type d -print0)

    while IFS= read -r -d '' file; do
      cp -p "$file" "$target/$file"
    done < <(find . -type f -print0)
  )
}

copy_dir "$plugin_root/agents" "$project_root/.claude/agents"
copy_dir "$plugin_root/agents-codex/compound-engineering" "$project_root/.agents/agents/compound-engineering"

exit 0
